.polaroid {
  position: relative;
  width: 100%;
  background: #fff;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  padding: 24rpx 24rpx 32rpx;
  box-sizing: border-box;
  animation: riseIn 0.32s ease-out both;
  transition: transform 0.2s, box-shadow 0.2s;
}

.polaroid.archived {
  opacity: 0.7;
}

.polaroid.selected {
  outline: 2rpx solid #333;
}

.polaroid-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.polaroid-inner {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.polaroid-media {
  position: relative;
  width: 100%;
  background: #f3f0ec;
  border-radius: 4rpx;
  overflow: hidden;
}

.polaroid-cover {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.polaroid-foot {
  min-height: 80rpx;
  padding-top: 8rpx;
}

.polaroid-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #111;
}

.polaroid-sub {
  font-size: 24rpx;
  margin-top: 6rpx;
}

.scent-dots {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  display: flex;
  gap: 6rpx;
  align-items: center;
}

.scent-dots .dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 4rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.archived-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.55);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #333;
  gap: 4rpx;
}

.archived-ico {
  font-size: 32rpx;
}

.line-clamp {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.text-muted {
  color: #666;
}
