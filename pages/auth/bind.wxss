.bind {
  padding: 32rpx;
}

.h2 {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tabs {
  display: flex;
  margin: 32rpx 0 16rpx;
  border-bottom: 1rpx solid #e5e0d8;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}

.tab.on {
  color: #111;
  font-weight: 600;
  border-bottom-color: #333;
}

.panel {
  padding: 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn {
  background: #333;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.code-input {
  background: #fff;
  border: 1rpx solid #e5e0d8;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 32rpx;
  letter-spacing: 6rpx;
}

.success-hint {
  margin-top: 40rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}
