.album {
  padding: 32rpx 24rpx 48rpx;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: 24rpx;
}

.greet {
  font-size: 40rpx;
  font-weight: 600;
  color: #111;
}

.stat {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.quota-tip {
  background: #fff;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 24rpx;
  color: #555;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.today-strip {
  margin-bottom: 24rpx;
}

.strip-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.strip-scroll {
  white-space: nowrap;
  width: 100%;
  height: 200rpx;
}

.strip-inner {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 0 0 8rpx;
  align-items: stretch;
  height: 200rpx;
}

.strip-item {
  width: 150rpx;
  height: 200rpx;
  flex: 0 0 auto;
  border-radius: 8rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.strip-cover {
  width: 100%;
  height: 100%;
}

.chips {
  white-space: nowrap;
  width: 100%;
  margin-bottom: 24rpx;
  display: flex;
  gap: 12rpx;
  flex-direction: row;
}

.chip {
  display: inline-flex;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: #fff;
  font-size: 24rpx;
  color: #666;
  border: 1rpx solid #e5e0d8;
}

.chip.on {
  background: #111;
  color: #fff;
  border-color: #111;
}

.select-bar {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #edeae6;
  padding: 12rpx 0;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.bar-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.link {
  background: transparent;
  color: #333;
}

.vlog {
  background: #333;
  color: #fff;
}

.empty {
  text-align: center;
  color: #666;
  padding: 100rpx 20rpx;
  font-size: 28rpx;
}

.empty-illus {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.month-block {
  margin-bottom: 32rpx;
}

.month-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #111;
}

.chev {
  font-size: 24rpx;
  color: #999;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.grid-cell {
  width: 50%;
  padding: 0 8rpx 20rpx;
  box-sizing: border-box;
  position: relative;
}

.select-mark {
  position: absolute;
  z-index: 5;
  right: 8rpx;
  top: 0;
  font-size: 32rpx;
  padding: 8rpx;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 8rpx;
}

.text-muted {
  color: #666;
}

.body {
  font-size: 28rpx;
  line-height: 1.5;
  margin: 8rpx 0 0;
}
