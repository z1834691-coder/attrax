.page {
  padding: 32rpx;
}

.card {
  background: #fff;
  border-radius: 8rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

.name {
  font-size: 34rpx;
  font-weight: 600;
}

.line {
  height: 1rpx;
  background: #e5e0d8;
  margin: 20rpx 0;
}

.row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ccc;
}
.dot.on {
  background: #6fa86f;
}

.sub {
  margin-top: 12rpx;
  font-size: 26rpx;
}

.sec {
  font-size: 24rpx;
  color: #666;
  margin: 20rpx 0 8rpx;
}

.big {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.bottles {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.b {
  width: 48%;
  background: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.bn {
  font-size: 28rpx;
  font-weight: 500;
}

.bar {
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  margin: 12rpx 0 8rpx;
  overflow: hidden;
}

.bf {
  height: 100%;
  background: #333;
  border-radius: 6rpx;
}

.bp {
  font-size: 22rpx;
  color: #666;
}

.btn {
  background: #333;
  color: #fff;
  border-radius: 8rpx;
  margin: 0 0 12rpx;
}

.tip {
  font-size: 22rpx;
}

.empty {
  padding: 60rpx;
  text-align: center;
  color: #666;
}

.text-muted {
  color: #666;
}
