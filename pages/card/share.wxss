.page {
  padding: 32rpx;
}

.h2 {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.cover {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
  background: #eee;
}

.meta {
  margin-top: 16rpx;
  font-size: 28rpx;
}

.title {
  margin-top: 24rpx;
  font-size: 36rpx;
  font-weight: 600;
}

.desc {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.row {
  display: flex;
  gap: 8rpx;
  margin-top: 20rpx;
}

.pill {
  width: 40rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.from {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.cta {
  margin-top: 40rpx;
  background: #333;
  color: #fff;
  border-radius: 8rpx;
}

.cta.outline {
  background: #fff;
  color: #333;
  border: 1rpx solid #333;
}

.empty {
  padding: 80rpx;
  text-align: center;
  color: #666;
}

.text-muted {
  color: #666;
}
