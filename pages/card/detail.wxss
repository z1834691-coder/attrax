.root {
  min-height: 100vh;
  background: #edeae6;
  padding-bottom: 140rpx;
}

.empty {
  padding: 100rpx;
  text-align: center;
  color: #666;
}

.detail {
  padding: 0 24rpx 24rpx;
}

.player-wrap {
  position: relative;
  width: 100%;
  height: 420rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #000;
  margin-top: 8rpx;
}

.live {
  width: 100%;
  height: 100%;
}

.live-img {
  display: block;
}

.block {
  margin-top: 24rpx;
}

.loc {
  font-size: 32rpx;
  font-weight: 500;
}

.time {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.section {
  margin-top: 32rpx;
}

.dim {
  font-size: 24rpx;
  color: #999;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.3;
  color: #111;
}

.desc {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
}

.recipe {
  margin-top: 32rpx;
  background: #fff;
  border-radius: 8rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.rh {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.r-label {
  width: 64rpx;
  font-size: 22rpx;
  color: #666;
}

.r-bar {
  flex: 1;
  height: 16rpx;
  background: #eee;
  border-radius: 8rpx;
  overflow: hidden;
}

.r-fill {
  height: 100%;
  border-radius: 8rpx;
}

.r-name {
  width: 200rpx;
  font-size: 22rpx;
  text-align: right;
  color: #444;
}

.sum {
  font-size: 22rpx;
  margin-top: 8rpx;
}

.note {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
  border: 1rpx dashed #e5e0d8;
}

.n-label {
  color: #999;
}

.pad-bottom {
  height: 24rpx;
}

.bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  background: rgba(237, 234, 230, 0.96);
  border-top: 1rpx solid #e5e0d8;
  padding: 12rpx 0;
  z-index: 100;
  padding-bottom: calc(12rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
}

.bar-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #333;
  padding: 20rpx 0;
}

.replay {
  font-weight: 600;
  color: #111;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 600px;
  height: 750px;
}

.rep-hint {
  position: fixed;
  left: 0;
  right: 0;
  top: 40%;
  text-align: center;
  z-index: 200;
  background: rgba(0, 0, 0, 0.65);
  color: #fff;
  margin: 0 80rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.text-muted {
  color: #666;
}

.safe-bottom {
  box-sizing: border-box;
}
